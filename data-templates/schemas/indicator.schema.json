{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/shadowhunter67/daklak-3d-dashboard/data-templates/schemas/indicator.schema.json",
  "title": "IndicatorDefinition and IndicatorObservation",
  "description": "Mirrors src/data-platform/schemas/indicator.ts — kept in sync by hand, see data-templates/README.md.",
  "definitions": {
    "indicatorDefinition": {
      "type": "object",
      "required": [
        "code",
        "name",
        "description",
        "domain",
        "unit",
        "valueType",
        "aggregation",
        "sourceDatasetId",
        "allowedAdministrativeLevels"
      ],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "domain": { "type": "string" },
        "unit": { "type": "string" },
        "valueType": { "enum": ["integer", "decimal", "percentage", "currency", "index"] },
        "aggregation": {
          "enum": ["sum", "average", "weighted-average", "latest", "none"]
        },
        "methodology": { "type": "string" },
        "numeratorIndicator": { "type": "string" },
        "denominatorIndicator": { "type": "string" },
        "sourceDatasetId": { "type": "string" },
        "allowedAdministrativeLevels": {
          "type": "array",
          "items": { "enum": ["province", "commune"] },
          "minItems": 1
        }
      }
    },
    "indicatorObservation": {
      "type": "object",
      "required": [
        "indicatorCode",
        "administrativeCode",
        "administrativeLevel",
        "period",
        "value",
        "status",
        "sourceDatasetId"
      ],
      "properties": {
        "indicatorCode": { "type": "string" },
        "administrativeCode": { "type": "string" },
        "administrativeLevel": { "enum": ["province", "commune"] },
        "period": { "type": "string" },
        "value": {
          "description": "null means missing — never use 0 as a stand-in.",
          "type": ["number", "null"]
        },
        "status": {
          "enum": ["official", "provisional", "estimated", "illustrative", "missing"]
        },
        "sourceDatasetId": { "type": "string" },
        "revision": { "type": "integer", "minimum": 1 },
        "updatedAt": { "type": "string" },
        "note": { "type": "string" }
      }
    }
  }
}
