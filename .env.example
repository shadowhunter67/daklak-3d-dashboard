# Detail map (MapLibre GL JS) configuration. Copy to .env.local for local overrides — never
# commit a real .env file. See docs/detail-map-integration.md for the full explanation.

# 'fake' renders a deterministic placeholder instead of a real map (used by default in
# development/CI so nobody needs a network tile source to run tests). 'maplibre' is the real
# provider and is what production must use.
VITE_DETAIL_MAP_PROVIDER=maplibre

# Self-hosted PMTiles/vector source for roads + administrative boundaries, e.g.
# /maps/daklak.pmtiles (same-origin, static hosting) or a CDN URL (see the CSP note below).
# Leave empty until a real PMTiles file is built and published — the detail map falls back to a
# background-only style and disables the road/boundary/heatmap/metric layer toggles with an
# explanation, rather than faking data.
VITE_DETAIL_MAP_SOURCE_URL=

# Self-hosted terrain-RGB or PMTiles DEM source. Leave empty to keep the "Địa hình" basemap option
# disabled (no terrain source currently exists for this project).
VITE_TERRAIN_SOURCE_URL=

# A licensed, web-permitted satellite raster tile URL template (e.g. {z}/{x}/{y}). Leave empty to
# keep the "Vệ tinh" basemap option disabled — never point this at Google/Bing/Esri tiles without
# an explicit license to do so.
VITE_SATELLITE_TILE_URL=

# NOTE: if VITE_DETAIL_MAP_SOURCE_URL/VITE_TERRAIN_SOURCE_URL/VITE_SATELLITE_TILE_URL ever point to
# a different origin (e.g. a CDN instead of same-origin static hosting), update the
# Content-Security-Policy meta tag in index.html (connect-src/img-src) accordingly — see SECURITY.md.
