{
  "name": "daklak-3d-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "build": "tsc -b && vite build",
    "check:budget": "node scripts/check_build_budget.mjs",
    "build:metrics": "node scripts/generate_build_metrics.mjs",
    "generate:public-manifest": "node scripts/generate_public_manifest.mjs",
    "validate:public-build": "node scripts/validate_public_build.mjs --mode=source",
    "validate:public-build:dist": "node scripts/validate_public_build.mjs --mode=dist",
    "quality:frontend": "npm run lint && npm run format:check && npm run typecheck && npm test && npm run generate:public-manifest && npm run validate:public-build && npm run build && npm run validate:public-build:dist && npm run check:budget && npm run build:metrics && npm run test:e2e:prod:built",
    "quality:full": "npm run check:gis-deps && npm run quality:frontend && npm run validate:data",
    "quality": "npm run quality:full",
    "check:gis-deps": "node scripts/check_gis_deps.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:prod": "npm run build && playwright test --config=playwright.prod.config.ts",
    "test:e2e:prod:built": "playwright test --config=playwright.prod.config.ts",
    "test:e2e:update": "playwright test --update-snapshots",
    "security:audit": "npm audit --audit-level=high",
    "security:secrets": "node scripts/check_secrets.mjs",
    "prepare:gis-source": "python scripts/prepare_gis_source.py",
    "prepare:gis-source:offline": "python scripts/prepare_gis_source.py --offline",
    "validate:data": "python scripts/validate_daklak_data.py",
    "build:gis": "npm run prepare:gis-source && python scripts/build_daklak_geojson.py",
    "build:terrain": "python scripts/generate_daklak_terrain.py",
    "build:roads": "python scripts/build_daklak_roads.py"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.0",
    "@react-three/fiber": "^9.4.0",
    "d3-geo": "^3.1.1",
    "maplibre-gl": "^5.24.0",
    "pmtiles": "^4.4.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "three": "^0.185.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.6.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.41.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
